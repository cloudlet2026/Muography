# Macro file for example B1
# 
# To be run preferably in batch, without graphics:
# % exampleB1 run2.mac
#
#/run/numberOfThreads 4
/run/initialize
#
/control/verbose 0
/run/verbose 1
#
/gps/particle mu-
/gps/position 0 0 90 cm
/gps/direction 0 0 -1
/gps/energy 3.0 GeV

/run/printProgress 1
/run/beamOn 10
